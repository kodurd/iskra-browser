{
  "manifest_version": 2,
  "name": "Iskra Customizer",
  "version": "1.0.0",
  "description": "Customize element colors on any website",
  "key": "",
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_16.png",
      "48": "icons/icon_48.png"
    },
    "default_title": "Iskra Customizer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
